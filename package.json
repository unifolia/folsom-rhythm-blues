{
  "name": "folsom-rhythm-blues",
  "version": "1.0.0",
  "description": "A polyrhythmic chord-progression metronome for the browser.",
  "private": true,
  "scripts": {
    "build": "esbuild poly.ts --bundle --minify --target=es2016 --outfile=poly.js",
    "watch": "esbuild poly.ts --bundle --target=es2016 --outfile=poly.js --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^6.0.0"
  }
}
